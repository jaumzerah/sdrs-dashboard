# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# LangSmith (US region)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=sua_chave_aqui
LANGSMITH_PROJECT=sdr-agents

# Postgres checkpointing (production profile)
POSTGRES_PORT=5433
POSTGRES_CHECKPOINT_URI=postgresql://postgres:postgres@localhost:5433/sdr_agents
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/sdr_agents

# Timeout do ciclo interno de avaliacao (segundos)
AVALIADOR_TIMEOUT_SEGUNDOS=30

# RabbitMQ (entrada de leads)
RABBITMQ_URI=amqp://guest:guest@localhost:5672/

# Worker de disparo
EVOLUTION_INSTANCE_DISPARO=   # instância do número descartável
DISPARO_DELAY_SEGUNDOS=30     # delay entre cada envio (segundos)

# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_aqui
EVOLUTION_INSTANCE=nome_da_instancia

# Chatwoot
CHATWOOT_URL=http://localhost:3000
CHATWOOT_API_TOKEN=seu_token_aqui
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1

# Identidade dos agentes SDR
OWNER_NAME=João Andrade
BRAND_NAME=           # Nome da marca (ex: LabMoveis ou SimplifiqueMoveis)
